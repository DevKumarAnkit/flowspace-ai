NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Clerk Billing feature slug created in the Clerk Dashboard for the Pro plan.
# The app checks this as user:pro_user.
CLERK_PRO_FEATURE=pro_user

# Server-only AssemblyAI Voice Agent configuration. Create the agent in AssemblyAI
# with Flowspace's clarification-and-confirmation prompt and action tool schema.
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_VOICE_AGENT_ID=
GEMINI_API_KEY=
